<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <!--
    DATABASE-FIRST project: the "SchoolDb" connection string below points at a
    database + Students table that ALREADY EXIST (created via Run_This_First.sql).
    Every line of this connection string is explained in the chat response.

    SECURITY: the Password value below is a PLACEHOLDER. Before running this
    project, edit this file LOCALLY and replace it with your real password -
    do NOT commit that edit back to git. App.config for a classic .NET
    Framework project like this one is compiled at build time, so there's no
    clean "gitignored local override" file the way appsettings.Development.json
    works for the .NET 8 projects elsewhere in this portfolio - just be careful
    not to `git add` this file after editing it locally.
  -->
  <connectionStrings>
    <add name="SchoolDb"
         connectionString="Server=192.168.1.52;Database=SchoolTest;User ID=SchoolCloud;Password=<YOUR_PASSWORD_HERE_DO_NOT_COMMIT>;MultipleActiveResultSets=true;TrustServerCertificate=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>
