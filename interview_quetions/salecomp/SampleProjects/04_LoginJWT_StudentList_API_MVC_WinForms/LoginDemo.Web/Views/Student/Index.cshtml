@model List<LoginDemo.Web.Models.StudentItem>
@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="display-6 mb-0">Students</h1>
        <p class="text-muted mb-0">Loaded from LoginDemo.Api's GET api/students, with the JWT from session sent as a Bearer token.</p>
    </div>
    <div class="text-end">
        <div class="text-muted small mb-1">Signed in as @ViewBag.FullName</div>
        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary btn-sm">Logout</a>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Class</th>
            <th>Roll Number</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="3" class="text-center text-muted">No students found.</td>
            </tr>
        }
        else
        {
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.Name</td>
                    <td>@student.Class</td>
                    <td>@student.RollNumber</td>
                </tr>
            }
        }
    </tbody>
</table>
