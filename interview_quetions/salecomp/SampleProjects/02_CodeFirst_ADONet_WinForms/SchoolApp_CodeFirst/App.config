<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <!--
    CODE-FIRST project: the "SchoolDb" connection string below points at the
    SAME SchoolTest database, but here the Students table does NOT need to
    exist yet - DatabaseInitializer.EnsureCreated() creates it from C# code
    the first time the app runs. Every line of this connection string is
    explained in the chat response.

    SECURITY: the Password value below is a PLACEHOLDER. Before running this
    project, edit this file LOCALLY and replace it with your real password -
    do NOT commit that edit back to git.
  -->
  <connectionStrings>
    <add name="SchoolDb"
         connectionString="Server=192.168.1.52;Database=SchoolTest;User ID=SchoolCloud;Password=<YOUR_PASSWORD_HERE_DO_NOT_COMMIT>;MultipleActiveResultSets=true;TrustServerCertificate=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>
